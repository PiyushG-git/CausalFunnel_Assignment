# Production backend URL (e.g. https://causalfunnel-backend.onrender.com/api)
# In development, leave empty — Vite proxy forwards /api to localhost:5000 automatically
VITE_API_URL=

# Optional API key — must match API_KEY set in the backend .env
# Leave empty in development (auth is disabled when backend API_KEY is not set)
VITE_API_KEY=
